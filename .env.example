# Required: ChatGPT session token copied from your browser cookies.
CHATGPT_SESSION_TOKEN=your_session_token_here

# Optional: CSRF token from chatgpt.com cookies.
# CHATGPT_CSRF_TOKEN=your_csrf_token_here

# Optional: enable verbose HTTP/auth debug logs.
DEBUG=false

# Optional: run Chrome headless. Keep this false while testing auth failures.
HEADLESS=false

# Optional: override the Chrome/Edge executable path.
# CHROME_PATH=/mnt/c/Program Files/Google/Chrome/Application/chrome.exe
